<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="14.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="eus.ehu.PrimaryController">
   <children>
      <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Mini Pokedex" />
      <HBox alignment="CENTER" spacing="28.0">
         <children>
            <ImageView fx:id="pokemonImage" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
            <VBox spacing="10.0">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="8.0">
                     <children>
                        <Label minWidth="70.0" text="ID:" />
                        <TextField fx:id="idField" editable="false" prefWidth="180.0" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="8.0">
                     <children>
                        <Label minWidth="70.0" text="Name:" />
                        <TextField fx:id="nameField" editable="false" prefWidth="180.0" />
                     </children>
                  </HBox>
                  <HBox alignment="TOP_LEFT" spacing="8.0">
                     <children>
                        <Label minWidth="70.0" text="Types:" />
                        <TextArea fx:id="typesArea" editable="false" prefHeight="74.0" prefWidth="180.0" wrapText="true" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="8.0">
                     <children>
                        <Label minWidth="70.0" text="Height:" />
                        <TextField fx:id="heightField" editable="false" prefWidth="180.0" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
      <HBox alignment="CENTER" spacing="12.0">
         <children>
            <Button fx:id="previousButton" onAction="#handlePrevious" text="Previous" />
            <Button fx:id="nextButton" onAction="#handleNext" text="Next" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
</VBox>